import java.util.ArrayList;
import java.util.List;
import java.util.Scanner;

public class StudentGradeCalculator {

    public static void main(String[] args) {
        StudentGradeCalculator calculator = new StudentGradeCalculator();
        calculator.run();
    }

    private void run() {
        Scanner scanner = new Scanner(System.in);

        int numberOfStudents = getNumberOfStudents(scanner);
        List<String> studentNames = new ArrayList<>();
        List<Double> studentGrades = new ArrayList<>();

        collectStudentData(scanner, numberOfStudents, studentNames, studentGrades);
        displayStudentReport(studentNames, studentGrades);

        double average = calculateAverage(studentGrades);
        System.out.printf("\nAverage Grade: %.2f%n", average);

        scanner.close();
    }

    private int getNumberOfStudents(Scanner scanner) {
        System.out.print("Enter the number of students: ");
        while (!scanner.hasNextInt()) {
            System.out.println("Invalid input. Please enter a valid number.");
            scanner.next();
        }
        return scanner.nextInt();
    }

    private void collectStudentData(Scanner scanner, int numberOfStudents, List<String> studentNames, List<Double> studentGrades) {
        for (int i = 0; i < numberOfStudents; i++) {
            System.out.print("Enter the name of student " + (i + 1) + ": ");
            String name = scanner.next();
            studentNames.add(name);

            System.out.print("Enter the grade of student " + (i + 1) + ": ");
            double grade = getValidGrade(scanner);
            studentGrades.add(grade);
        }
    }

    private double getValidGrade(Scanner scanner) {
        while (!scanner.hasNextDouble()) {
            System.out.println("Invalid input. Please enter a valid grade.");
            scanner.next();
        }
        return scanner.nextDouble();
    }

    private void displayStudentReport(List<String> studentNames, List<Double> studentGrades) {
        System.out.println("\nStudent Grade Report:");
        for (int i = 0; i < studentNames.size(); i++) {
            System.out.printf("%s: %.2f%n", studentNames.get(i), studentGrades.get(i));
        }
    }

    private double calculateAverage(List<Double> grades) {
        return grades.stream()
                .mapToDouble(Double::doubleValue)
                .average()
                .orElse(0.0);
    }
}
